{
  "name": "hodoscope-ai",
  "description": "Visualize Git PR history as interactive particle traces with deep-dive PR detail panels. Works with GitHub & Azure DevOps.",
  "version": "0.1.0",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "git",
    "pull-request",
    "visualization",
    "github",
    "azure-devops",
    "hodoscope",
    "t-sne"
  ],
  "scripts": {
    "generate": "tsx scripts/demo-scatter.ts",
    "start": "serve dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "azure-devops-node-api": "^14.0.0",
    "d3": "^7.9.0",
    "serve": "^14.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^2.1.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "puppeteer": "^24.40.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
